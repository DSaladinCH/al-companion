{
	"name": "al-companion",
	"publisher": "DSaladin",
	"displayName": "AL Companion",
	"description": "Companion extension for working with Microsoft AL / Business Central",
	"author": {
		"email": "support@dsaladin.dev",
		"name": "Dominic Saladin"
	},
	"license": "MIT",
	"version": "0.2.1",
	"icon": "logo_small.png",
	"engines": {
		"vscode": "^1.109.0"
	},
	"categories": [
		"Other",
		"Programming Languages"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/DSaladinCH/al-companion.git"
	},
	"bugs": {
		"url": "https://github.com/DSaladinCH/al-companion/issues",
		"email": "support@dsaladin.dev"
	},
	"funding": [
		{
			"type": "Buy Me a Coffee",
			"url": "https://www.buymeacoffee.com/dsaladin"
		}
	],
	"galleryBanner": {
		"color": "#62a9ff",
		"theme": "dark"
	},
	"keywords": [
		"AL",
		"Business Central",
		"Microsoft Dynamics 365",
		"Extension Development"
	],
	"activationEvents": [
		"workspaceContains:app.json"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "al-companion.reloadPackages",
				"title": "AL Companion: Reload Packages"
			},
			{
				"command": "al-companion.searchEventSubscriber",
				"title": "AL Companion: Search Event Subscriber"
			},
			{
				"command": "al-companion.searchLocalFiles",
				"title": "AL Companion: Search Local Files"
			},
			{
				"command": "al-companion.jumpToFunctionLine",
				"title": "AL Companion: Jump to Function Line"
			}
		],
		"keybindings": [
			{
				"command": "al-companion.searchLocalFiles",
				"key": "alt+shift+f",
				"when": "resourceExtname == '.al' || editorLangId == 'al'"
			}
		],
		"configuration": {
			"title": "AL Companion",
			"properties": {
				"al-companion.debugLogging": {
					"type": "boolean",
					"default": false,
					"description": "Enable debug logging to the AL Companion output channel."
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run bundle",
		"bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"lint": "eslint src",
		"package": "vsce package",
		"publish": "vsce publish"
	},
	"devDependencies": {
		"@types/jszip": "^3.4.0",
		"@types/node": "22.x",
		"@types/vscode": "^1.109.0",
		"@vscode/vsce": "^2.25.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"jszip": "^3.10.1"
	},
	"overrides": {
		"yauzl": "^3.2.1",
		"flatted": "^3.4.0"
	}
}
